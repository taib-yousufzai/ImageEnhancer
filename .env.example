# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=5

# Maximum output file size in MB
MAX_OUTPUT_SIZE_MB=1

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-production-site.com,http://localhost:3000

# Comma-separated list of SHA-256 hashed API Keys (do not store plain text here!)
ALLOWED_API_KEY_HASHES=

# Maximum concurrent processing tasks to prevent memory crash
MAX_CONCURRENT_TASKS=50

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Python version for deployment
PYTHON_VERSION=3.10.0
